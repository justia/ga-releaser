{
  "name": "@justia/releaser",
  "version": "2.1.1",
  "description": "A script to generate releases and changelog",
  "keywords": [
    "justia",
    "release",
    "changelog",
    "internal",
    "tool",
    "github",
    "action"
  ],
  "homepage": "https://github.com/justia/front-end-projects/tree/master/packages/releaser#readme",
  "bugs": {
    "url": "https://github.com/justia/front-end-projects/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justia/front-end-projects.git",
    "directory": "packages/releaser"
  },
  "license": "MIT",
  "author": "Alonso Zuniga <alonso.zuniga@justia.com>",
  "main": "index.js",
  "module": "index.js",
  "bin": {
    "jReleaser": "cli/index.js"
  },
  "directories": {
    "test": "test"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "utilities.js",
    "utilities.d.ts",
    "github.js",
    "github.d.ts",
    "releaser.d.ts",
    "cli/**/*.js",
    "log/*.js",
    "log/*.d.ts",
    "plugins/*.js",
    "plugins/*.d.ts"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "postbuild": "rimraf cli/*.d.ts cli/**/*.d.ts",
    "clean": "tsc -b tsconfig.build.json --clean",
    "format": "prettier --write --parser=json-stringify '**/*.json' && sort-package-json",
    "lint": "eslint . --ext .ts --fix --report-unused-disable-directives",
    "prepublishOnly": "safe-publish-latest",
    "rebuild": "npm run clean && npm run build",
    "status": "npm test",
    "poststatus": "npm run typecheck",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "jest": {
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/__tests__/**/*.+(ts|tsx|js)",
      "**/?(*.)+(spec|test).+(ts|tsx|js)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    }
  },
  "dependencies": {
    "@actions/core": "^1.8.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^5.0.1",
    "@octokit/plugin-rest-endpoint-methods": "^5.13.0",
    "@release-it/conventional-changelog": "^4.3.0",
    "calver": "~21.1.5",
    "conventional-recommended-bump": "^6.1.0",
    "release-it": "^14.14.3",
    "type-fest": "^2.12.2",
    "yaml": "^2.0.1"
  },
  "devDependencies": {
    "@types/conventional-recommended-bump": "^6.1.0"
  },
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "81e7f905919b47aa2496f61fd5b6af1077f580c3"
}
